DISCORD_TOKEN=put-your-discord-bot-token-here

# Optional: where alerts go. Leave blank to reply in the same channel.
MOD_LOG_CHANNEL_ID=

# Bot behavior
DELETE_FLAGGED_MESSAGES=false
REPLY_TO_FLAGGED_MESSAGES=true
ENABLE_TEST_TRIGGERS=false
NSFW_THRESHOLD=0.75
ENABLE_LOCAL_NSFW=true
LOCAL_NSFW_MODEL=onnx-community/nsfw_image_detection-ONNX
LOCAL_NSFW_CACHE_DIR=.cache/transformers
# Keep true for the first run so the public model can download once, then you can set false.
LOCAL_NSFW_ALLOW_REMOTE_MODELS=true
SCAM_THRESHOLD=55
BAD_WRITING_THRESHOLD=45
BAD_SPEECH_THRESHOLD=45
CUSTOM_BAD_SPEECH_TERMS=
DELETE_BAD_SPEECH_MESSAGES=true

# Local AI replies when the bot is mentioned.
ENABLE_AI_REPLIES=true
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:0.5b
AI_REPLY_TIMEOUT_MS=12000
AI_REPLY_MAX_CHARS=900

# VirusTotal link scanning.
# Get a key at https://www.virustotal.com/gui/my-apikey
ENABLE_LINK_SCANNING=true
VT_API_KEY=
VT_MALICIOUS_THRESHOLD=1
VT_SUSPICIOUS_THRESHOLD=2
VT_SUBMIT_UNKNOWN_URLS=false
VT_ANALYSIS_WAIT_MS=2000
LINK_SCAN_TIMEOUT_MS=10000
LINK_SCAN_MAX_URLS=3
DELETE_BAD_LINK_MESSAGES=true
